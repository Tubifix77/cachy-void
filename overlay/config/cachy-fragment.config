# Cachy-Void kernel config fragment — architecture.md §2.4 (source of truth).
# Appended to the upstream dotconfig by §8.4 regeneration; verified symbol-by-
# symbol by the G2 gate (§8.5) against the generated .config after oldconfig.
# Runtime copy: /etc/cachy-void/cachy-fragment.config (installed by deploy.sh).
# --- Scheduler: BORE on top of EEVDF ---
CONFIG_SCHED_BORE=y
CONFIG_SCHED_AUTOGROUP=y
# --- Timer: 1000 Hz for input latency ---
CONFIG_HZ_1000=y
CONFIG_HZ=1000
# CONFIG_HZ_100 is not set
# CONFIG_HZ_250 is not set
# CONFIG_HZ_300 is not set
# --- Preemption: full, pinned ---
CONFIG_PREEMPT=y
# CONFIG_PREEMPT_NONE is not set
# CONFIG_PREEMPT_VOLUNTARY is not set
# CONFIG_PREEMPT_DYNAMIC is not set
# --- Memory: MGLRU on by default, THP always ---
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED=y
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=y
# --- Network: BBR built IN (not a module) + fq qdisc ---
# We deliberately do NOT flip the "default TCP congestion" Kconfig CHOICE here:
# a dotconfig APPEND cannot override a choice already satisfied by cubic, so
# oldconfig drops DEFAULT_BBR/DEFAULT_TCP_CONG (G2 caught this on the first real
# kernel run — real-hardware finding). The runtime default is set instead by
# net.ipv4.tcp_congestion_control=bbr (§3.1 sysctl, already applied at boot).
# Building BBR IN (=y, vs the stock =m) is the part that matters: it removes the
# module-load ordering risk so that sysctl can never silently fail (§2.4).
CONFIG_TCP_CONG_BBR=y
CONFIG_NET_SCH_FQ=y
