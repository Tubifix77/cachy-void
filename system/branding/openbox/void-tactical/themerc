# void-tactical — Cachy-Void openbox theme (branding.md palette). Applied by cachy-branding.
border.width: 1
padding.width: 5
padding.height: 4
window.handle.width: 0
window.client.padding.width: 0
menu.overlap.x: 0
menu.overlap.y: 0

# active window
window.active.title.bg: flat solid
window.active.title.bg.color: #1b1d1e
window.active.title.separator.color: #1b1d1e
window.active.label.bg: parentrelative
window.active.label.text.color: #abb2bf
window.active.border.color: #478061
window.active.client.color: #478061
window.active.button.unpressed.bg: parentrelative
window.active.button.unpressed.image.color: #abb2bf
window.active.button.hover.bg: parentrelative
window.active.button.hover.image.color: #478061
window.active.button.pressed.bg: parentrelative
window.active.button.pressed.image.color: #478061
window.active.button.disabled.image.color: #5c6370

# inactive window
window.inactive.title.bg: flat solid
window.inactive.title.bg.color: #16181a
window.inactive.title.separator.color: #16181a
window.inactive.label.bg: parentrelative
window.inactive.label.text.color: #5c6370
window.inactive.border.color: #282c34
window.inactive.button.unpressed.bg: parentrelative
window.inactive.button.unpressed.image.color: #5c6370
window.inactive.button.hover.bg: parentrelative
window.inactive.button.hover.image.color: #abb2bf

# openbox menu
menu.border.color: #282c34
menu.title.bg: flat solid
menu.title.bg.color: #282c34
menu.title.text.color: #abb2bf
menu.items.bg: flat solid
menu.items.bg.color: #1b1d1e
menu.items.text.color: #abb2bf
menu.items.disabled.text.color: #5c6370
menu.items.active.bg: flat solid
menu.items.active.bg.color: #478061
menu.items.active.text.color: #1b1d1e
menu.separator.color: #282c34

# osd
osd.bg: flat solid
osd.bg.color: #1b1d1e
osd.border.color: #478061
osd.label.text.color: #abb2bf
osd.hilight.bg: flat solid
osd.hilight.bg.color: #478061
osd.unhilight.bg: flat solid
osd.unhilight.bg.color: #282c34
