-- Cachy-Void Conky — minimal honest telemetry (branding.md §5.5). Text only, no gauges.
-- Host-specific fields (net iface, hwmon index, GPU and battery lines) are filled
-- in by cachy-branding at apply time; GPU/BAT lines are dropped on machines that
-- lack them. The placeholder tokens sit on their own lines in conky.text below.
conky.config = {
    alignment = 'top_right', gap_x = 30, gap_y = 52,
    minimum_width = 210, maximum_width = 260,
    -- own_window_type='normal' (not 'desktop'): 'desktop' vanishes when the
    -- pcmanfm-qt desktop is clicked (raises its window over Conky). See conky#399.
    -- own_window_class='Conky' so the compositor's shadow-exclude (picom.conf,
    -- class_g='Conky') matches — otherwise a 'normal' window gets a dark shadow-line.
    own_window = true, own_window_type = 'normal', own_window_class = 'Conky',
    own_window_argb_visual = true, own_window_argb_value = 0, own_window_transparent = true,
    own_window_hints = 'undecorated,below,sticky,skip_taskbar,skip_pager',
    double_buffer = true, update_interval = 2.0,
    draw_shades = false, draw_borders = false, use_xft = true,
    font = 'Hack:size=9', default_color = 'abb2bf', color1 = '478061', color2 = '5c6370',
}
conky.text = [[
${color1}CACHY-VOID${color}
${color2}${nodename} · ${kernel}${color}
${color1}cpu ${color}${cpu}%   ${color1}temp ${color}${hwmon @HWMON@ temp 1}°C
${color1}mem ${color}${memperc}%   ${color2}${mem}/${memmax}${color}
@GPU_LINE@
@BAT_LINE@
${color1}net ${color}${downspeed @NET_IFACE@} v ${upspeed @NET_IFACE@} ^
${color1}up  ${color}${uptime_short}
]]
