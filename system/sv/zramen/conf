# Cachy-Void zram configuration — architecture.md §3.2
#
# Installed to /etc/sv/zramen/conf by deploy.sh and sourced by the zramen
# runit service. Pairs with vm.swappiness=100 (§3.1): a large zstd-compressed
# swap keeps the page cache hot under memory pressure.
#
# NOTE: these variable names follow the zramen package's documented interface
# and MUST be verified against the installed version (`cat /etc/sv/zramen/run`),
# per the explicit caveat in architecture.md §3.2.
export ZRAM_ALG=zstd     # zstd: best ratio (~3:1) at acceptable CPU cost
export ZRAM_SIZE=1.0     # fraction of physical RAM (1.0 ≈ 100%, safe at ~3:1)
export ZRAM_PRIO=100     # above any disk swap so zram is used first
