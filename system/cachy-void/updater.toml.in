# Cachy-Void updater configuration — architecture.md §4.1 / §8.9.
#
# Auto-generated by deploy.sh with sane defaults (void_packages filled from the
# detected checkout). EDIT to taste — especially the [packages] allowlist, the
# ONLY packages ever compiled locally. Re-running deploy.sh will NOT overwrite
# this file once it exists.

[paths]
void_packages = "@VOID_PACKAGES@"

[build]
jobs = 0        # 0 = nproc

[packages]
# The ONLY packages compiled locally (rebuilt at the etc/conf -march/-O3). Seed set:
targets = ["linux-cachy", "mesa", "vulkan-loader", "SDL2",
           "pipewire", "wireplumber", "wine", "gamemode", "mangohud", "ffmpeg"]
# Never build these (bootstrap layer, invariant I2) — always the upstream binary:
blacklist = ["glibc", "musl", "gcc", "binutils", "xbps", "runit", "base-files"]

[services]
# Managed by runit but never auto-restarted (session-fatal); reported instead:
restart_skip = ["udevd", "dbus", "elogind"]

[kernel]
enable = true

[snapshot]
# §9.5 pre-deploy btrfs snapshot. "auto" = snapshot only on btrfs (silent no-op
# on ext4); true = require btrfs and abort if absent; false = never.
enable = "auto"
subvol = "/"
dir    = "/.cachy-snapshots"
keep   = 5
