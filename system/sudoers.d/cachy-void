# Cachy-Void updater privilege boundary — architecture.md §4.1
#
# The orchestrator runs as an unprivileged build user and reaches root ONLY
# through the exact commands it invokes in Stage 4 (atomic install, service
# detection via xcheckrestart, runit service cycling via sv), recovery (pkgdb
# repair), and §8.6 kernel boot staging (the three narrow GRUB binaries).
# Nothing else is granted. (xcheckrestart reads every process's /proc/*/maps,
# so it must run as root to see system daemons — §4.7.)
#
# Installed 0440 root:root and validated with `visudo -c` before activation.
# The user in the grant line below is filled in by deploy.sh.
# §9.5 (optional btrfs snapshots) adds exactly three btrfs subvolume ops —
# snapshot -r / delete / list — for the pre-deploy rollback net + its prune.
# --clean (maintenance) adds exactly the two xbps-remove forms below: orphan
# removal (-o) and obsolete-cache cleaning (-O), each preview (-n) and apply
# (-y). These flags cannot name a package, so the grant can only remove orphans
# or tidy the cache — never an arbitrary package. Kernel purges stay MANUAL
# (§2.5/§4.7): vkpurge is deliberately NOT granted here.
Cmnd_Alias CACHY_VOID_UPDATE = /usr/bin/xbps-install, /usr/bin/sv, /usr/bin/xcheckrestart, \
    /usr/bin/xbps-pkgdb, /usr/bin/grub-set-default, /usr/bin/grub-reboot, /usr/bin/grub-editenv, \
    /usr/sbin/btrfs subvolume snapshot -r *, /usr/sbin/btrfs subvolume delete *, /usr/sbin/btrfs subvolume list *, \
    /usr/bin/xbps-remove -o -n, /usr/bin/xbps-remove -o -y, /usr/bin/xbps-remove -O -n, /usr/bin/xbps-remove -O -y

@USER@ ALL=(root) NOPASSWD: CACHY_VOID_UPDATE
