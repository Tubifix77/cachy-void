#!/usr/bin/env bash
# cachy-branding — apply (or remove) the Cachy-Void "void-tactical" LXQt look.
# branding.md is the design spec; this is the applier. Runs as YOUR user (LXQt
# config is per-user; never root). OPT-IN and REVERSIBLE: every file it changes
# is backed up once as <file>.pre-cachy.bak, and `--remove` restores them.
#
#   cachy-branding            apply the void-tactical desktop
#   cachy-branding --remove   restore the pre-branding desktop from backups
#
# Composes: Kvantum widget skin (fork of KvArcDark, recoloured), LXQt panel theme
# (fork of the 'kvantum' theme, blue->green), Papirus-Dark + grey folders, openbox
# void-tactical titlebars, top-bar + Plank dock layout, Picom matte shadows, Rofi
# launcher (Super+Space), Conky telemetry, and the flagship wallpaper.
set -uo pipefail

ASSETS="${CACHY_BRANDING_ASSETS:-/usr/share/cachy-void/branding}"
BG=1b1d1e; PANEL=282c34; FG=abb2bf; ACCENT=478061; DIM=5c6370
CFG="$HOME/.config"; SHARE="$HOME/.local/share"

if [ -t 1 ]; then C=$'\033[0;36m'; K=$'\033[0;32m'; W=$'\033[0;33m'; Z=$'\033[0m'
else C=""; K=""; W=""; Z=""; fi
log(){ printf '%s==>%s %s\n' "$C" "$Z" "$*"; }
ok(){ printf '%s ok%s %s\n' "$K" "$Z" "$*"; }
warn(){ printf '%swarn%s %s\n' "$W" "$Z" "$*" >&2; }
bak(){ [ -e "$1" ] && [ ! -e "$1.pre-cachy.bak" ] && cp -a "$1" "$1.pre-cachy.bak"; }

[ "$(id -u)" -ne 0 ] || { warn "run as your normal user, not root (LXQt config is per-user)"; exit 1; }
[ -d "$ASSETS" ] || { warn "branding assets not found at $ASSETS (deploy.sh installs them)"; exit 1; }

if [ "${1:-}" = "--remove" ]; then
    log "restoring pre-branding config from backups"
    for f in "$CFG"/lxqt/lxqt.conf "$CFG"/lxqt/session.conf "$CFG"/lxqt/panel.conf \
             "$CFG"/Kvantum/kvantum.kvconfig "$CFG"/openbox/rc.xml \
             "$CFG"/lxqt/lxqt-powermanagement.conf "$CFG"/gtk-3.0/settings.ini \
             "$CFG"/pcmanfm-qt/lxqt/settings.conf; do
        [ -e "$f.pre-cachy.bak" ] && mv -f "$f.pre-cachy.bak" "$f" && ok "restored $f"
    done
    if command -v gsettings >/dev/null 2>&1; then
        gsettings reset org.gnome.desktop.interface icon-theme 2>/dev/null
        gsettings reset org.gnome.desktop.interface gtk-theme 2>/dev/null
        gsettings reset org.gnome.desktop.interface color-scheme 2>/dev/null
    fi
    # strip our gtk.css block (the Plank-dot tint); leave any user rules intact
    GC="$CFG/gtk-3.0/gtk.css"
    [ -f "$GC" ] && python3 - "$GC" <<'PY'
import re,sys
p=sys.argv[1]; t=open(p).read()
t=re.sub(r"\n*/\* >>> cachy-void >>> \*/.*?/\* <<< cachy-void <<< \*/\n*","\n",t,flags=re.S)
open(p,"w").write(t)
PY
    rm -rf "$SHARE/icons/Luv-Void"
    _desk=$(xdg-user-dir DESKTOP 2>/dev/null); [ -d "$_desk" ] || _desk="$HOME/Desktop"
    rm -f "$_desk/cachy-updater.desktop" "$CFG/plank/dock1/launchers/00-cachy-updater.dockitem"
    rm -f "$SHARE/applications/cachy-trash.desktop" "$CFG/plank/dock1/launchers/zz-trash.dockitem"
    # (restoring pcmanfm settings.conf above brings the desktop shortcut icons back on next login)
    rm -rf "$SHARE/lxqt/themes/void-tactical" "$CFG/Kvantum/void-tactical" "$HOME/.themes/void-tactical"
    rm -f "$CFG"/autostart/{picom,plank,conky,conky-system,xcape}.desktop
    rm -f "$CFG"/conky/conky-system.conf
    # openbox session autostart + root menu: restore a pre-existing one, else drop ours
    for _obf in openbox/autostart openbox/menu.xml openbox/environment tint2/tint2rc; do
        if [ -e "$CFG/$_obf.pre-cachy.bak" ]; then
            mv -f "$CFG/$_obf.pre-cachy.bak" "$CFG/$_obf"
        else
            rm -f "$CFG/$_obf"
        fi
    done
    command -v papirus-folders >/dev/null 2>&1 && sudo papirus-folders -C blue -t Papirus-Dark 2>/dev/null
    pkill -x picom 2>/dev/null; pkill -x plank 2>/dev/null; pkill -x conky 2>/dev/null; pkill -x xcape 2>/dev/null; pkill -x tint2 2>/dev/null
    pkill -f lxqt-powermanagement 2>/dev/null; command -v lxqt-powermanagement >/dev/null 2>&1 && setsid lxqt-powermanagement >/dev/null 2>&1 &
    ok "removed — log out/in for a full reset."
    exit 0
fi

# --- session env (so live restarts reach the running LXQt) ---
SP=$(pgrep -u "$USER" -x lxqt-session | head -1)
if [ -n "$SP" ]; then while IFS= read -r -d '' kv; do export "$kv"; done < "/proc/$SP/environ"; fi
case "${XDG_CURRENT_DESKTOP:-}" in *LXQt*) : ;; *) warn "not an LXQt session — this look targets LXQt/X11; applying config anyway" ;; esac

# ============================================================ Kvantum widget skin
log "Kvantum widget skin (void-tactical)"
KVSRC=/usr/share/Kvantum/KvArcDark
if [ -d "$KVSRC" ]; then
    D="$CFG/Kvantum/void-tactical"; mkdir -p "$D"
    cp -f "$KVSRC/KvArcDark.svg" "$D/void-tactical.svg"
    sed -i -E "s/#5294e2/#$ACCENT/Ig; s/#4d8fd8/#$ACCENT/Ig; s/#4877b1/#3a6b52/Ig; s/#0582ff/#$ACCENT/Ig; s/#4693e6/#$ACCENT/Ig; s/#58acff/#5a9678/Ig; s/#3176bf/#3a6b52/Ig; s/#b74aff/#$DIM/Ig" "$D/void-tactical.svg"
    python3 - "$KVSRC/KvArcDark.kvconfig" "$D/void-tactical.kvconfig" "$BG" "$PANEL" "$FG" "$ACCENT" "$DIM" <<'PY'
import re,sys
src,dst,BG,PANEL,FG,ACCENT,DIM=sys.argv[1:8]
t=open(src).read()
gc=f"""[GeneralColors]
window.color=#{BG}
base.color=#{BG}
alt.base.color=#202327
button.color=#{PANEL}
light.color=#3a3f4b
mid.light.color=#23262b
dark.color=#0f1011
mid.color=#141517
highlight.color=#{ACCENT}
inactive.highlight.color=#3a4d43
text.color=#{FG}
window.text.color=#{FG}
button.text.color=#{FG}
disabled.text.color=#{DIM}
tooltip.text.color=#{FG}
highlight.text.color=#{BG}
link.color=#{ACCENT}
link.visited.color=#{DIM}
progress.indicator.text.color=#{BG}
"""
t=re.sub(r"\[GeneralColors\].*?(?=\n\[)",gc.rstrip()+"\n",t,count=1,flags=re.S)
for b in ("#5796e8","#009DFF","#5294e2"): t=t.replace(b,"#"+ACCENT)
t=t.replace("#9E4FFF","#"+DIM)
for wv in ("#ffffffc8","#eefcff","#ffffffd2"): t=t.replace(wv,"#"+FG)
for wv in ("#ffffff96","#ffffff78","#ffffff73","#000000b4"): t=t.replace(wv,"#"+DIM)
open(dst,"w").write(t)
PY
    printf '[General]\ntheme=void-tactical\n' > "$CFG/Kvantum/kvantum.kvconfig"
    ok "Kvantum -> void-tactical"
else warn "KvArcDark not installed (kvantum pkg) — skipping Kvantum skin"; fi

# ============================================================ LXQt panel theme
log "LXQt panel theme (void-tactical, blue->green)"
LXSRC=/usr/share/lxqt/themes/kvantum
if [ -d "$LXSRC" ]; then
    D="$SHARE/lxqt/themes/void-tactical"; rm -rf "$D"; mkdir -p "$D"; cp -rf "$LXSRC"/. "$D"/
    find "$D" -type f \( -name '*.qss' -o -name '*.svg' \) -print0 | xargs -0 sed -i -E \
     -e 's/#55aaff/#6a9d84/Ig' -e 's/#80c0ff/#7fae95/Ig' -e 's/#81c0ff/#7fae95/Ig' \
     -e 's/#4da6ff/#5a9678/Ig' -e 's/#488cc8/#4f8a6b/Ig' -e 's/#4584be/#4f8a6b/Ig' \
     -e 's/#4d8fd2/#558f70/Ig' -e 's/#3a72a0/#3f7259/Ig' -e 's/#3a5f84/#3a6b52/Ig' \
     -e 's/#436d98/#45775c/Ig' -e 's/#2878c8/#478061/Ig' -e 's/#246cb4/#3f7259/Ig' \
     -e 's/#006edc/#4a8666/Ig' -e 's/#0064c8/#478061/Ig' -e 's/#005ab4/#3f7259/Ig' \
     -e 's/#0050a0/#3a6b52/Ig' -e 's/#375778/#2e4d3f/Ig' -e 's/#385a7c/#2e4d3f/Ig' \
     -e 's/#345372/#2c4a3c/Ig' -e 's/#2e4964/#282c34/Ig' -e 's/#001e3c/#16211b/Ig' \
     -e 's/#001428/#121a15/Ig'
    # underplay the panel background gradient. The base theme fades the bar to
    # near-black (rgba(0,0,0,72%)) at its bottom edge, which reads as a hard dark
    # band sitting on the obsidian wallpaper. Take that bottom stop down to just a
    # tad darker than the wallpaper (~rgb(27,29,30)) instead, so the bar melts into
    # the desktop — the crisp light-grey top edge is kept. The rgba string is unique
    # to the four #BackgroundWidget rules, so this targeted replace is safe.
    find "$D" -type f -name '*.qss' -print0 | xargs -0 sed -i \
        's/rgba(0, 0, 0, 72%)/rgba(22, 24, 25, 90%)/g'
    # kill the plugin move-handle "dots" (the taskbar/tray grip). The theme draws
    # them via Plugin[NeedsHandle="true"] + plugin-handle-*.svg; lockPanel is meant
    # to hide them but doesn't in LXQt 2.4, so null the image (last-wins override,
    # matching the per-position selectors' specificity) and reclaim their margin.
    if [ -f "$D/lxqt-panel.qss" ]; then
        cat >> "$D/lxqt-panel.qss" <<'QSS'

/* cachy-void: remove the plugin move-handle dots (clean, locked-looking panel).
   Must be `background: none` (shorthand) — `background-image: none` alone does
   NOT clear it in Qt QSS. */
LXQtPanel[position="Bottom"] Plugin[NeedsHandle="true"],
LXQtPanel[position="Top"] Plugin[NeedsHandle="true"],
LXQtPanel[position="Left"] Plugin[NeedsHandle="true"],
LXQtPanel[position="Right"] Plugin[NeedsHandle="true"] {
    background: none;
    margin: 0;
    padding: 0;
}

/* cachy-void: clock font = Hack, to match Conky's telemetry */
#WorldClockContent { font-family: "Hack"; }

/* cachy-void: flat active taskbar button (kills the base theme's metallic gradient) */
#TaskBar QToolButton:on { background-color: #2e4d3f; border: 1px solid #478061; }
#TaskBar QToolButton:hover:on { background-color: #3a6b52; border: 1px solid #478061; }
QSS
    fi
    ok "LXQt theme -> void-tactical (handle dots removed)"
else warn "LXQt 'kvantum' theme not present — panel keeps current theme"; fi

# ============================================================ icon theme (Luv-Void — mono)
# Build "Luv-Void": the Luv icon theme (deploy.sh fetches it to $ASSETS/luv) with
# every colour desaturated to its luminance grey. Done at the SVG level (not a
# grayscale <filter>, which Qt's SVG renderer ignores) so it renders mono in both
# LXQt/Qt AND GTK/Plank. Full app coverage means no colourful hicolor leak (Steam
# stays grey). Falls back to Papirus-Dark if the Luv source isn't present.
log "icon theme (Luv-Void — mono)"
ICON_THEME="Papirus-Dark"
LUVSRC="$ASSETS/luv/Luv"; LVDST="$SHARE/icons/Luv-Void"
if [ -d "$LUVSRC" ]; then
    if [ ! -f "$LVDST/index.theme" ]; then
        rm -rf "$LVDST"; mkdir -p "$SHARE/icons"
        cp -rL "$LUVSRC" "$LVDST"   # -L flattens symlinks so desaturation reaches every file
        python3 - "$LVDST" <<'PY'
import re,os,sys
root=sys.argv[1]
def lum(r,g,b):
    y=round(0.299*r+0.587*g+0.114*b); return '#%02x%02x%02x'%(y,y,y)
h6=re.compile(r'#([0-9a-fA-F]{6})\b'); h3=re.compile(r'#([0-9a-fA-F]{3})\b')
rf=re.compile(r'rgb\((\d+)\s*,\s*(\d+)\s*,\s*(\d+)\)')
r6=lambda m:lum(int(m.group(1)[0:2],16),int(m.group(1)[2:4],16),int(m.group(1)[4:6],16))
r3=lambda m:lum(int(m.group(1)[0]*2,16),int(m.group(1)[1]*2,16),int(m.group(1)[2]*2,16))
rr=lambda m:lum(int(m.group(1)),int(m.group(2)),int(m.group(3)))
for dp,_,fs in os.walk(root):
    for f in fs:
        if f.endswith('.svg'):
            q=os.path.join(dp,f)
            try: t=open(q,encoding='utf-8',errors='ignore').read()
            except: continue
            t2=rf.sub(rr,h3.sub(r3,h6.sub(r6,t)))
            if t2!=t: open(q,'w',encoding='utf-8').write(t2)
PY
        # alias LXQt/dock names Luv lacks -> Luv's own equivalents (mono)
        for d in "$LVDST"/apps/*/; do
            [ -f "${d}system-file-manager.svg" ] && ln -sf system-file-manager.svg "${d}pcmanfm-qt.svg"
            [ -f "${d}utilities-terminal.svg" ] && ln -sf utilities-terminal.svg "${d}qterminal.svg"
        done
        command -v gtk-update-icon-cache >/dev/null 2>&1 && gtk-update-icon-cache -f "$LVDST" 2>/dev/null
    fi
    [ -f "$LVDST/index.theme" ] && ICON_THEME="Luv-Void"
fi
ok "icon theme = $ICON_THEME"

# ============================================================ LXQt appearance (lxqt.conf / session.conf)
log "LXQt appearance (Kvantum style, $ICON_THEME, Hack, palette)"
mkdir -p "$CFG/lxqt"; LX="$CFG/lxqt/lxqt.conf"; bak "$LX"
python3 - "$LX" "$BG" "$PANEL" "$FG" "$ACCENT" "$DIM" "$ICON_THEME" <<'PY'
import sys,configparser,os
p,BG,PANEL,FG,ACCENT,DIM,ICON=sys.argv[1:8]
c=configparser.RawConfigParser(); c.optionxform=str
if os.path.exists(p): c.read(p)
def s(sec,k,v):
    if not c.has_section(sec): c.add_section(sec)
    c.set(sec,k,v)
s('General','__userfile__','true'); s('General','icon_theme',ICON); s('General','theme','void-tactical')
s('Qt','style','kvantum'); s('Qt','font_family','Hack'); s('Qt','font_point_size','10')
for k,v in {'base_color':'#'+BG,'window_color':'#'+BG,'text_color':'#'+FG,'window_text_color':'#'+FG,
            'highlight_color':'#'+ACCENT,'highlighted_text_color':'#'+BG,'link_color':'#'+ACCENT,
            'link_visited_color':'#'+DIM,'tooltip_base_color':'#000000','tooltip_text_color':'#'+FG}.items():
    s('Palette',k,v)
with open(p,'w') as f: c.write(f,space_around_delimiters=False)
PY
SC="$CFG/lxqt/session.conf"; bak "$SC"
grep -q '^QT_STYLE_OVERRIDE=' "$SC" 2>/dev/null || { grep -q '^\[Environment\]' "$SC" 2>/dev/null || printf '\n[Environment]\n' >> "$SC"; printf 'QT_STYLE_OVERRIDE=kvantum\n' >> "$SC"; }
# GTK apps + Plank use their OWN theme keys (NOT lxqt.conf) — point them at ours.
# Widget theme: Arc-Dark (pairs with our KvArcDark-based Kvantum) so GTK apps like
# Firefox get dark chrome; +prefer-dark so Firefox's "auto" theme picks dark. Falls
# back to Adwaita-dark. (GTK reads its theme at startup — restart GTK apps to apply.)
GTK_THEME="Adwaita-dark"; [ -d /usr/share/themes/Arc-Dark ] && GTK_THEME="Arc-Dark"
mkdir -p "$CFG/gtk-3.0"; GT="$CFG/gtk-3.0/settings.ini"; bak "$GT"
[ -s "$GT" ] || printf '[Settings]\n' > "$GT"
setgtk(){ grep -q "^$1=" "$GT" && sed -i "s|^$1=.*|$1=$2|" "$GT" || sed -i "/^\[Settings\]/a $1=$2" "$GT"; }
setgtk gtk-icon-theme-name "$ICON_THEME"
setgtk gtk-theme-name "$GTK_THEME"
setgtk gtk-application-prefer-dark-theme true
if command -v gsettings >/dev/null 2>&1; then
    gsettings set org.gnome.desktop.interface icon-theme "$ICON_THEME" 2>/dev/null
    gsettings set org.gnome.desktop.interface gtk-theme "$GTK_THEME" 2>/dev/null
    gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' 2>/dev/null
fi
# Plank's running-indicator dot is NOT a themeable dock.theme key — libplank derives
# it from the GTK theme's `iconview.view` background colour (Arc-Dark ships blue-grey,
# so the dot renders blue). Override that one colour in the user gtk.css to tint the
# dot brand green. pcmanfm-qt is Qt (unaffected); GTK apps don't paint chrome from
# iconview.view, so the blast radius is just Plank's dot. Marked block = --remove-able.
GC="$CFG/gtk-3.0/gtk.css"
python3 - "$GC" "$ACCENT" <<'PY'
import os,re,sys
p,accent=sys.argv[1],sys.argv[2]
t=open(p).read() if os.path.exists(p) else ""
t=re.sub(r"\n*/\* >>> cachy-void >>> \*/.*?/\* <<< cachy-void <<< \*/\n*","\n",t,flags=re.S)
block=("/* >>> cachy-void >>> */\n"
       "/* Plank derives its running-indicator dot from iconview.view's background;\n"
       "   tint it brand green (dock.theme has no key for this). */\n"
       f"iconview.view {{ background-color: #{accent}; }}\n"
       "/* <<< cachy-void <<< */\n")
open(p,"w").write((t.rstrip()+"\n\n" if t.strip() else "")+block)
PY
ok "lxqt.conf + session.conf + GTK theme ($GTK_THEME) + icon theme + Plank dot"

# ============================================================ openbox titlebars
log "openbox titlebars (void-tactical)"
OT="$HOME/.themes/void-tactical/openbox-3"; mkdir -p "$OT"; cp -f "$ASSETS/openbox/void-tactical/themerc" "$OT/themerc"
RC="$CFG/openbox/rc.xml"; mkdir -p "$CFG/openbox"
[ -f "$RC" ] || { [ -f /etc/xdg/openbox/rc.xml ] && cp /etc/xdg/openbox/rc.xml "$RC"; }
bak "$RC"
if [ -f "$RC" ]; then
    python3 - "$RC" <<'PY'
import re,sys
p=sys.argv[1]; t=open(p).read()
if re.search(r'<theme>.*?<name>',t,re.S): t=re.sub(r'(<theme>.*?<name>).*?(</name>)',r'\1void-tactical\2',t,count=1,flags=re.S)
elif '</openbox_config>' in t: t=t.replace('</openbox_config>','<theme><name>void-tactical</name></theme>\n</openbox_config>')
# one virtual desktop (the 4-desktop default is dated; re-add if wanted)
if '<desktops>' in t: t=re.sub(r'(<number>)\s*\d+\s*(</number>)', r'\g<1>1\g<2>', t, count=1)
elif '<openbox_config' in t: t=re.sub(r'(<openbox_config[^>]*>)', r'\1\n<desktops><number>1</number></desktops>', t, count=1)
# Super+Space -> rofi
if '</keyboard>' in t and 'rofi -show' not in t:
    t=t.replace('</keyboard>','  <keybind key="W-space"><action name="Execute"><command>rofi -show drun</command></action></keybind>\n</keyboard>')
open(p,'w').write(t)
PY
    ok "openbox -> void-tactical (+ 1 desktop, Super+Space rofi)"
else warn "no openbox rc.xml — titlebar theme + rofi keybind skipped"; fi

# ============================================================ openbox session autostart
# Make the BARE "Openbox" greeter session usable + branded. Without it, picking
# Openbox = a black screen (openbox draws no panel/wallpaper of its own — that is
# normal, not a crash). LXQt uses its OWN XDG autostart and ignores this file, so
# nothing double-starts. Minimal + WM-appropriate: wallpaper (feh) + compositor +
# Conky telemetry; launch apps via the openbox root menu or Super+Space (rofi).
log "openbox session autostart (branded bare-openbox)"
# tint2 panel config (the taskbar — without it, launched windows can hide behind
# others / on another monitor with no way to reach them: "nothing happens").
mkdir -p "$CFG/tint2"; TT="$CFG/tint2/tint2rc"; bak "$TT"
[ -f "$ASSETS/tint2/tint2rc" ] && cp -f "$ASSETS/tint2/tint2rc" "$TT"
OBA="$CFG/openbox/autostart"; bak "$OBA"
_wp="$SHARE/cachy-void/cachy-void-official.png"
_kbd="$(setxkbmap -query 2>/dev/null | awk '/^layout/{print $2}')"
{
    printf '#!/bin/sh\n'
    printf '# cachy-void: minimal branded Openbox session (regenerated by cachy-branding).\n'
    printf '# Runs ONLY under the bare Openbox session; LXQt uses XDG autostart instead.\n'
    [ -n "$_kbd" ] && printf 'setxkbmap %s 2>/dev/null &\n' "$_kbd"
    { command -v feh >/dev/null 2>&1 && [ -f "$_wp" ]; } && \
        printf 'feh --no-fehbg --bg-fill "%s" 2>/dev/null &\n' "$_wp"
    [ -f "$CFG/picom/picom.conf" ] && \
        printf 'picom --config "$HOME/.config/picom/picom.conf" 2>/dev/null &\n'
    command -v tint2 >/dev/null 2>&1 && printf 'tint2 2>/dev/null &\n'
    [ -f "$CFG/conky/conky.conf" ] && \
        printf '(sleep 2; conky -c "$HOME/.config/conky/conky.conf") &\n'
    [ -f "$CFG/conky/conky-system.conf" ] && \
        printf '(sleep 2; env LC_CTYPE=C.UTF-8 conky -c "$HOME/.config/conky/conky-system.conf") &\n'
} > "$OBA"
chmod +x "$OBA"
command -v feh >/dev/null 2>&1 || warn "feh not installed — openbox session has no wallpaper (deploy.sh --with-branding installs it)"
ok "openbox autostart -> wallpaper + picom + conky${_kbd:+ + keyboard $_kbd}$(command -v tint2 >/dev/null 2>&1 && printf ' + tint2 panel')"

# Curated openbox ROOT MENU (right-click). Openbox's stock /etc/xdg/openbox/menu.xml
# is a generic 48-entry list hard-coding apps from every DE (KDE/GNOME/XFCE/OpenOffice)
# — almost all uninstalled, so it looks like "residue from an old DE". A user menu.xml
# overrides it: essentials + "Applications" via rofi (dynamic — only shows what's
# installed, never goes stale). Entries self-adjust to the tools actually present.
OBM="$CFG/openbox/menu.xml"; bak "$OBM"
_term=""; for t in qterminal xterm sakura alacritty kitty; do command -v "$t" >/dev/null 2>&1 && { _term="$t"; break; }; done
_fm="";   for f in pcmanfm-qt pcmanfm; do command -v "$f" >/dev/null 2>&1 && { _fm="$f"; break; }; done
_br="";   for b in firefox chromium; do command -v "$b" >/dev/null 2>&1 && { _br="$b"; break; }; done
{
  printf '<?xml version="1.0" encoding="UTF-8"?>\n<openbox_menu xmlns="http://openbox.org/3.4/menu">\n'
  printf '  <menu id="root-menu" label="Cachy-Void">\n'
  printf '    <item label="Applications"><action name="Execute"><command>rofi -show drun</command></action></item>\n'
  printf '    <item label="Run"><action name="Execute"><command>rofi -show run</command></action></item>\n'
  printf '    <separator/>\n'
  [ -n "$_term" ] && printf '    <item label="Terminal"><action name="Execute"><command>%s</command></action></item>\n' "$_term"
  [ -n "$_fm" ]   && printf '    <item label="Files"><action name="Execute"><command>%s</command></action></item>\n' "$_fm"
  [ -n "$_br" ]   && printf '    <item label="Web Browser"><action name="Execute"><command>%s</command></action></item>\n' "$_br"
  printf '    <separator/>\n'
  printf '    <item label="Reconfigure Openbox"><action name="Reconfigure"/></item>\n'
  printf '    <separator/>\n'
  printf '    <item label="Log Out"><action name="Exit"><prompt>yes</prompt></action></item>\n'
  if command -v loginctl >/dev/null 2>&1; then
    printf '    <item label="Reboot"><action name="Execute"><command>loginctl reboot</command></action></item>\n'
    printf '    <item label="Shut Down"><action name="Execute"><command>loginctl poweroff</command></action></item>\n'
  fi
  printf '  </menu>\n</openbox_menu>\n'
} > "$OBM"
ok "openbox root menu -> curated (rofi + essentials; stale stock menu bypassed)"

# Dark Qt for the bare Openbox session. LXQt exports these via its session.conf;
# openbox does NOT, so Qt apps (qterminal, pcmanfm-qt, the updater GUI) render in a
# LIGHT default style there. openbox-session sources ~/.config/openbox/environment
# at startup, so exporting them here themes every Qt app dark (Kvantum void-tactical).
OBE="$CFG/openbox/environment"; bak "$OBE"
{
  printf '# cachy-void: dark Qt theme for the Openbox session (Kvantum void-tactical).\n'
  printf '# LXQt sets these via session.conf; openbox needs them here so Qt apps\n'
  printf '# (qterminal, pcmanfm-qt, the updater GUI) are dark, not the light default.\n'
  printf 'export QT_QPA_PLATFORMTHEME=lxqt\n'
  printf 'export QT_STYLE_OVERRIDE=kvantum\n'
} > "$OBE"
ok "openbox session -> dark Qt (Kvantum) for qterminal/pcmanfm-qt/updater"

# ============================================================ Papirus grey folders (only on the Papirus fallback)
if [ "$ICON_THEME" = "Papirus-Dark" ] && command -v papirus-folders >/dev/null 2>&1; then
    log "folder colour: grey"; sudo papirus-folders -C grey -t Papirus-Dark >/dev/null 2>&1 && ok "folders grey" || warn "papirus-folders needs sudo — folders unchanged"
fi

# ============================================================ wallpaper
log "wallpaper (cachy-void-official)"
WP="$SHARE/cachy-void/cachy-void-official.png"; mkdir -p "$SHARE/cachy-void"
# always (re)render from the SVG — a stale PNG must not survive an asset update
if [ -f "$ASSETS/wallpapers/cachy-void-official.svg" ]; then
    if command -v rsvg-convert >/dev/null 2>&1; then rsvg-convert -w 1920 -h 1080 "$ASSETS/wallpapers/cachy-void-official.svg" -o "$WP"
    else magick -background none "$ASSETS/wallpapers/cachy-void-official.svg" -resize 1920x1080 "$WP" 2>/dev/null; fi
fi
# pcmanfm-qt caches the decoded wallpaper by PATH — a same-name content change is
# ignored (needs a desktop restart). Point it at a fresh versioned copy each apply
# so the path changes and it reloads live; prune older versions.
WPV="$SHARE/cachy-void/cachy-void-official-$(date +%s).png"
cp -f "$WP" "$WPV" 2>/dev/null && find "$SHARE/cachy-void" -maxdepth 1 -name 'cachy-void-official-*.png' ! -name "$(basename "$WPV")" -delete 2>/dev/null
[ -f "$WPV" ] || WPV="$WP"
PS="$CFG/pcmanfm-qt/lxqt/settings.conf"
if [ -f "$PS" ]; then
    bak "$PS"
    sed -i -E "s#^Wallpaper=.*#Wallpaper=$WPV#; s#^WallpaperMode=.*#WallpaperMode=stretch#" "$PS"
    # clean desktop (played-down §5.7): NO desktop icons — the file manager (Plank)
    # is the single entry point; home/computer/network/trash are reached inside it.
    # DesktopShortcuts= empty removes the special icons; HideItems MUST stay false
    # (HideItems=true blanks the wallpaper too). pcmanfm materializes the shortcuts
    # as ~/Desktop/*.desktop files AND rewrites DesktopShortcuts back to defaults on
    # a graceful exit — so apply-live kills it with -9 (no write-back) and this edit
    # lands for the next clean start (a re-login applies it definitively).
    grep -q '^DesktopShortcuts=' "$PS" && sed -i 's/^DesktopShortcuts=.*/DesktopShortcuts=/' "$PS" || sed -i '/^\[Desktop\]/a DesktopShortcuts=' "$PS"
    grep -q '^HideItems=' "$PS" && sed -i 's/^HideItems=.*/HideItems=false/' "$PS" || sed -i '/^\[Desktop\]/a HideItems=false' "$PS"
fi
rm -f "$HOME"/Desktop/{computer,network,trash-can,user-home,steam}.desktop 2>/dev/null
# keep trash reachable: a Trash launcher (mono icon) — pinned to Plank below
mkdir -p "$SHARE/applications"
printf '[Desktop Entry]\nType=Application\nName=Trash\nComment=Open the trash\nExec=pcmanfm-qt trash:///\nIcon=user-trash\nTerminal=false\nCategories=System;\n' > "$SHARE/applications/cachy-trash.desktop"
command -v pcmanfm-qt >/dev/null 2>&1 && pcmanfm-qt --set-wallpaper="$WPV" --wallpaper-mode=stretch 2>/dev/null
ok "wallpaper set; desktop icons cleared (Plank is the launcher)"

# ============================================================ panel: top bar
# Surgical: keep the user's existing (working) panel.conf and only nudge
# position/size/plugin-list — do NOT rebuild [panel1]/[mainmenu] from scratch.
# A from-scratch rewrite was tried and shipped a menu-less panel (the mainmenu
# plugin silently failed to render); editing the live config in place is safe.
log "panel: move top, thinner, drop desktop switcher"
PC="$CFG/lxqt/panel.conf"
[ -f "$PC" ] || { [ -f /etc/xdg/lxqt/panel.conf ] && mkdir -p "$CFG/lxqt" && cp /etc/xdg/lxqt/panel.conf "$PC"; }
bak "$PC"
mkdir -p "$SHARE/cachy-void"
cp -f "$ASSETS/void-cachy-icon.svg" "$SHARE/cachy-void/void-cachy-icon.svg" 2>/dev/null
if command -v rsvg-convert >/dev/null 2>&1; then rsvg-convert -w 64 -h 64 "$SHARE/cachy-void/void-cachy-icon.svg" -o "$SHARE/cachy-void/void-cachy-icon.png"
else magick -background none "$SHARE/cachy-void/void-cachy-icon.svg" -resize 64x64 "$SHARE/cachy-void/void-cachy-icon.png" 2>/dev/null; fi
if [ -f "$PC" ]; then
    python3 - "$PC" "$SHARE/cachy-void/void-cachy-icon.png" <<'PY'
import sys,re
p,icon=sys.argv[1],sys.argv[2]
t=open(p).read()

def section(t, sec):
    return re.search(r'(\['+re.escape(sec)+r'\]\n)(.*?)(?=\n\[|\Z)', t, re.S)

def set_in_section(t, sec, kvs, create=False):
    """Set key=val pairs inside [sec]. Edits the plugin's OWN config section —
    never fabricates a plugin instance (that broke rendering before)."""
    m=section(t, sec)
    if m:
        head,body=m.group(1),m.group(2)
        for k,v in kvs:
            if re.search(r'^%s='%re.escape(k), body, re.M):
                body=re.sub(r'^%s=.*$'%re.escape(k), '%s=%s'%(k,v), body, count=1, flags=re.M)
            else:
                body=body.rstrip('\n')+'\n%s=%s\n'%(k,v)
        return t[:m.start()]+head+body+t[m.end():]
    if create:
        block='['+sec+']\n'+''.join('%s=%s\n'%(k,v) for k,v in kvs)
        return t.rstrip('\n')+'\n\n'+block+'\n'
    return t

menu=None
m=section(t,'panel1')
if m:
    head,body=m.group(1),m.group(2)
    def setkv(body,key,val):
        if re.search(r'^%s='%key, body, re.M): return re.sub(r'^%s=.*$'%key, '%s=%s'%(key,val), body, count=1, flags=re.M)
        return key+'='+val+'\n'+body
    body=setkv(body,'position','Top')
    # lock the panel: an unlocked LXQt panel draws grip dots between plugins.
    body=setkv(body,'lockPanel','true')
    if re.search(r'^panelSize=', body, re.M):
        body=re.sub(r'^panelSize=.*$', 'panelSize=30', body, count=1, flags=re.M)
    pm=re.search(r'^plugins=(.*)$', body, re.M)
    if pm:
        items=[x.strip() for x in pm.group(1).split(',') if x.strip()]
        items=[x for x in items if x not in ('desktopswitch','pager','showdesktop')]
        for cand in items:
            if cand.split('_')[0] in ('fancymenu','mainmenu'): menu=cand; break
        body=re.sub(r'^plugins=.*$', 'plugins='+', '.join(items), body, count=1, flags=re.M)
    t=t[:m.start()]+head+body+t[m.end():]

# swap the menu button icon on whichever menu plugin this panel actually uses.
# fancymenu needs ownIcon=true to honour a custom icon; mainmenu just takes icon=.
# Its config section is safe to create (the instance already exists in plugins=).
if menu:
    kind=menu.split('_')[0]
    if kind=='fancymenu':
        t=set_in_section(t, menu, [('ownIcon','true'),('icon',icon)], create=True)
    else:  # mainmenu
        t=set_in_section(t, menu, [('icon',icon)], create=True)
open(p,'w').write(t)
print('menu plugin:', menu or '(none found)')
PY
    ok "panel -> top, thinner, desktop switcher dropped, menu-button icon swapped"
else
    warn "no panel.conf found (and no /etc/xdg default) — panel layout unchanged"
fi

# ============================================================ Plank dock
if command -v plank >/dev/null 2>&1; then
    log "Plank dock (flat, dodge-maximized, app launchers only)"
    PT="$SHARE/plank/themes/void-tactical"; mkdir -p "$PT" "$CFG/plank/dock1/launchers"
    cp -f "$ASSETS/plank/void-tactical/dock.theme" "$PT/dock.theme"
    for app in pcmanfm-qt qterminal steam firefox; do
        f=$(ls /usr/share/applications/ 2>/dev/null | grep -iE "(^|\.)$app\.desktop$" | head -1)
        [ -n "$f" ] && printf '[PlankDockItemPreferences]\nLauncher=file:///usr/share/applications/%s\n' "$f" > "$CFG/plank/dock1/launchers/$app.dockitem"
    done
    # the Cachy-Void updater, if its launcher is installed (deploy.sh --with-branding)
    [ -f /usr/share/applications/cachy-updater.desktop ] && \
        printf '[PlankDockItemPreferences]\nLauncher=file:///usr/share/applications/cachy-updater.desktop\n' > "$CFG/plank/dock1/launchers/00-cachy-updater.dockitem"
    # trash (replaces the removed desktop trash icon) — last in the dock
    [ -f "$SHARE/applications/cachy-trash.desktop" ] && \
        printf '[PlankDockItemPreferences]\nLauncher=file://%s/applications/cachy-trash.desktop\n' "$SHARE" > "$CFG/plank/dock1/launchers/zz-trash.dockitem"
    DK="net.launchpad.plank.dock.settings:/net/launchpad/plank/docks/dock1/"
    for kv in "theme void-tactical" "icon-size 40" "hide-mode dodge-maximized" "zoom-enabled false" "position bottom" "alignment center" "items-alignment center"; do
        gsettings set $DK ${kv%% *} "${kv#* }" 2>/dev/null
    done
    # delayed autostart: on this "this-PC" TV setup, Plank launching before the
    # TV output is fully negotiated leaves it stranded near the old (laptop
    # panel) screen center until next restart. A short delay lets X/xrandr
    # settle on the real output first.
    printf '[Desktop Entry]\nType=Application\nName=plank\nExec=sh -c "sleep 8 && exec plank"\n' > "$CFG/autostart/plank.desktop"
    ok "Plank configured"
fi

# ============================================================ updater launcher on the desktop
if [ -f /usr/share/applications/cachy-updater.desktop ]; then
    DESK=$(xdg-user-dir DESKTOP 2>/dev/null); [ -d "$DESK" ] || DESK="$HOME/Desktop"
    if [ -d "$DESK" ]; then
        cp -f /usr/share/applications/cachy-updater.desktop "$DESK/cachy-updater.desktop"
        chmod +x "$DESK/cachy-updater.desktop"
        # pcmanfm-qt honours the trusted flag → launches without the "untrusted" prompt
        command -v gio >/dev/null 2>&1 && gio set "$DESK/cachy-updater.desktop" metadata::trusted true 2>/dev/null
        ok "updater launcher on the desktop ($DESK)"
    fi
fi

# ============================================================ Picom / Rofi / Conky configs
mkdir -p "$CFG/picom" "$CFG/rofi" "$CFG/conky" "$CFG/autostart"
[ -f "$ASSETS/picom.conf" ] && cp -f "$ASSETS/picom.conf" "$CFG/picom/picom.conf"
printf '[Desktop Entry]\nType=Application\nName=picom\nExec=picom --config %s/picom/picom.conf\n' "$CFG" > "$CFG/autostart/picom.desktop"
cp -f "$ASSETS/rofi/config.rasi" "$CFG/rofi/config.rasi"
# conky: fill host-specific iface + hwmon
IFACE=$(ip route 2>/dev/null | awk '/^default/{print $5; exit}'); : "${IFACE:=eth0}"
HW=$(for h in /sys/class/hwmon/hwmon*; do [ "$(cat $h/name 2>/dev/null)" = coretemp ] && basename "$h" | tr -dc 0-9 && break; done); : "${HW:=0}"
# GPU line: query the nvidia chip directly (nvidia-smi), not the game overlay
# path — on legacy Optimus/PRIME render-offload MangoHud/NVML load% is unreliable,
# but nvidia-smi's own reads are direct chip queries. Kepler cards (GT 730M etc.)
# return [N/A] for util/power/clocks while temp + memory still read fine, so the
# awk below prints ONLY the fields that came back as real numbers — self-adjusting
# per card (a modern GPU also shows util%). One nvidia-smi call per 5s (execi).
GPU_LINE=""
if command -v nvidia-smi >/dev/null 2>&1 && [ -n "$(nvidia-smi -L 2>/dev/null)" ]; then
    # Build the line at APPLY time from whichever fields the card reports as real
    # numbers (Kepler returns [N/A] for util). Colours + units live in the STATIC
    # template, and each value is a SIMPLE ${execi} (no braces / no ${} inside the
    # command) — conky's parser mis-nests on ${color} embedded in an exec command
    # (execpi) and truncates it, so keep exec commands bare. Green labels + units
    # match the cpu/mem lines: gpu NN°C   load NN%   vram U/TMB.
    q(){ nvidia-smi --query-gpu="$1" --format=csv,noheader,nounits 2>/dev/null | head -1 | tr -d ' '; }
    isnum(){ case "$1" in ''|*[!0-9.]*) return 1;; *) return 0;; esac; }
    E='--format=csv,noheader,nounits 2>/dev/null'
    seg='${color1}gpu ${color}'
    if isnum "$(q temperature.gpu)"; then
        seg="$seg"'${execi 5 nvidia-smi --query-gpu=temperature.gpu '"$E"'}°C'
    fi
    if isnum "$(q utilization.gpu)"; then
        seg="$seg"'   ${color1}load ${color}${execi 5 nvidia-smi --query-gpu=utilization.gpu '"$E"'}%'
    fi
    TOTAL="$(q memory.total)"   # constant — bake it in, only "used" is dynamic
    if isnum "$(q memory.used)" && isnum "$TOTAL"; then
        seg="$seg"'   ${color1}vram ${color}${execi 5 nvidia-smi --query-gpu=memory.used '"$E"'}/'"$TOTAL"'MB'
    fi
    GPU_LINE="$seg"
fi
# Battery line: only on machines with a battery (laptops). We hide the lxqt-power
# management tray icon (below) and surface charge + AC state here instead — honest
# text, no widget. acpiacadapter reports on-line/off-line -> AC/batt via if_match.
BAT_LINE=""
BATDEV=$(ls -d /sys/class/power_supply/BAT* 2>/dev/null | head -1)
if [ -n "$BATDEV" ]; then
    BN=$(basename "$BATDEV")
    ACDEV=$(ls -d /sys/class/power_supply/AC* /sys/class/power_supply/ADP* 2>/dev/null | head -1); AN=$(basename "${ACDEV:-AC0}")
    BAT_LINE='${color1}bat ${color}${battery_percent '"$BN"'}%   ${color2}${if_match "${acpiacadapter '"$AN"'}"=="on-line"}AC${else}batt${endif}${color}'
fi
sed -e "s/@NET_IFACE@/$IFACE/g" -e "s/@HWMON@/$HW/g" "$ASSETS/conky/conky.conf.in" | \
    awk -v gpu="$GPU_LINE" -v bat="$BAT_LINE" '
        $0=="@GPU_LINE@" { if (gpu != "") print gpu; next }
        $0=="@BAT_LINE@" { if (bat != "") print bat; next }
        { print }' > "$CFG/conky/conky.conf"
# delayed autostart: same TV-detection race as Plank — gap_x/gap_y anchoring
# (top_right) gets computed against whatever screen geometry is live when
# conky starts, so it drifts if that's the wrong output.
printf '[Desktop Entry]\nType=Application\nName=conky\nExec=sh -c "sleep 8 && exec conky -c %s/conky/conky.conf"\n' "$CFG" > "$CFG/autostart/conky.desktop"

# --- left "SYSTEM" identity panel (the "what it IS" spec-sheet) --------------
# A second, static Conky anchored middle-left, to balance the two right-side
# blocks (telemetry top-right + wordmark bottom-right). Every value is read from
# the running system here at apply time — honest, self-adjusting (unknown fields
# are dropped, never printed as [N/A]), so it also documents the actual fusion:
# Void form (runit/xbps/glibc/snooze) + CachyOS substance (BORE/1000Hz/preempt).
# Python reads the template + writes the final conf itself (encoding='utf-8') — going
# through a shell $(...) var + awk double-encodes the box's UTF-8 glyphs (─ × ·) when
# the ssh/login locale isn't UTF-8. Keeping it all in Python is byte-safe.
python3 - "$ASSETS/conky/conky-system.conf.in" "$CFG/conky/conky-system.conf" <<'PY'
import gzip, os, re, shutil, subprocess, sys

def sh(*c):
    try: return subprocess.run(c, capture_output=True, text=True, timeout=6).stdout
    except Exception: return ""

def read(p):
    try:
        with open(p) as f: return f.read()
    except Exception: return ""

# -- SYSTEM ---------------------------------------------------------------
osname = ""
for ln in read("/etc/os-release").splitlines():
    if ln.startswith("PRETTY_NAME="): osname = ln.split("=",1)[1].strip().strip('"'); break
osname = osname or "Void Linux"

libc = ""
v = sh("ldd", "--version")
m = re.search(r"GNU libc\)\s*([0-9.]+)", v) or re.search(r"\b([0-9]+\.[0-9]+)\b", v)
if "musl" in v.lower() or os.path.exists("/lib/ld-musl-x86_64.so.1"):
    libc = "musl" + (" " + m.group(1) if m else "")
elif m:
    libc = "glibc " + m.group(1)

flags = set()
model = ""
for ln in read("/proc/cpuinfo").splitlines():
    if ln.startswith("flags") and not flags: flags = set(ln.split(":",1)[1].split())
    if ln.startswith("model name") and not model: model = ln.split(":",1)[1].strip()
if {"avx512f"} <= flags:                                 arch = "x86_64-v4"
elif {"avx2","bmi2","fma"} <= flags:                     arch = "x86_64-v3"
elif {"sse4_2","popcnt"} <= flags:                       arch = "x86_64-v2"
else:                                                    arch = "x86_64"

cron = "snooze" if shutil.which("snooze") else ""

# -- KERNEL (read the RUNNING kernel's config, not assumptions) -----------
kcfg = ""
try: kcfg = gzip.open("/proc/config.gz","rt").read()
except Exception: kcfg = read("/boot/config-" + os.uname().release)
def has(sym): return re.search(r"^%s=y" % re.escape(sym), kcfg, re.M) is not None
ksched = "BORE" if has("CONFIG_SCHED_BORE") else ("EEVDF" if kcfg else "")
mhz = re.search(r"^CONFIG_HZ=(\d+)", kcfg, re.M)
ktick = (mhz.group(1) + " Hz") if mhz else ""
kpreempt = "full" if has("CONFIG_PREEMPT") else ("voluntary" if has("CONFIG_PREEMPT_VOLUNTARY") else ("none" if kcfg else ""))
thp = ""
mt = re.search(r"\[(\w+)\]", read("/sys/kernel/mm/transparent_hugepage/enabled"))
if mt: thp = mt.group(1)
mit = "off" if "mitigations=off" in read("/proc/cmdline") else "on"
swp = read("/proc/sys/vm/swappiness").strip()

# -- HARDWARE -------------------------------------------------------------
cpu = re.sub(r"\(R\)|\(TM\)", "", model)
cpu = re.sub(r"\s*@.*$", "", cpu)
cpu = re.sub(r"\b(Intel|Core|CPU|Processor)\b", "", cpu)
cpu = re.sub(r"\s+", " ", cpu).strip()
if cpu and os.cpu_count(): cpu += " ×%d" % os.cpu_count()

gpu = sh("nvidia-smi", "--query-gpu=name", "--format=csv,noheader").strip().splitlines()
gpu = gpu[0] if gpu else ""
if not gpu:
    for ln in sh("sh","-c","lspci 2>/dev/null | grep -Ei 'vga|3d'").splitlines():
        gpu = re.sub(r".*: ", "", ln).strip(); break
gpu = re.sub(r"NVIDIA\s*|GeForce\s*|Corporation\s*", "", gpu).strip()

drvver = read("/sys/module/nvidia/version").strip()
driver = ("nvidia " + drvver) if drvver else ""

memkb = re.search(r"MemTotal:\s*(\d+)", read("/proc/meminfo"))
mem = ("%.2f GiB" % (int(memkb.group(1))/1048576)) if memkb else ""

root = ""
for ln in read("/proc/mounts").splitlines():
    p = ln.split()
    if len(p) > 2 and p[1] == "/": root = p[2]; break

zram = "active" if os.path.exists("/sys/block/zram0") else ""
if zram and shutil.which("zramen"): zram += " · zramen"

# -- render ---------------------------------------------------------------
def line(label, val):
    return "${color1}%-8s${color}%s" % (label, val) if val else None

out = []
def section(title, items):
    body = [x for x in (line(l, v) for l, v in items) if x]
    if not body: return
    if out: out.append("")
    out.append("${color1}%s${color}" % title)
    out.append("${color2}%s${color}" % ("─" * 16))
    out.extend(body)

section("SYSTEM", [("os", osname), ("libc", libc), ("arch", arch),
                   ("init", "runit"), ("pkg", "xbps"), ("cron", cron)])
section("KERNEL", [("sched", ksched), ("tick", ktick), ("preempt", kpreempt),
                   ("thp", thp), ("vm.swap", swp), ("mitig.", mit)])
section("HARDWARE", [("cpu", cpu), ("gpu", gpu), ("driver", driver),
                     ("mem", mem), ("root", root), ("zram", zram)])

tmpl, dest = sys.argv[1], sys.argv[2]
with open(tmpl, encoding="utf-8") as f: t = f.read()
with open(dest, "w", encoding="utf-8") as f:
    f.write(t.replace("@SYSTEM_TEXT@", "\n".join(out)))
PY
# Force a UTF-8 ctype on launch: the panel's ─ / × / · glyphs render as mojibake if
# conky decodes the (UTF-8) config under a non-UTF-8 LC_CTYPE. The panel has no
# locale-sensitive numbers, so pinning LC_CTYPE=C.UTF-8 is a no-downside guarantee
# (unlike the telemetry Conky, whose decimal formatting we leave to the session locale).
printf '[Desktop Entry]\nType=Application\nName=conky-system\nExec=sh -c "sleep 8 && exec env LC_CTYPE=C.UTF-8 conky -c %s/conky/conky-system.conf"\n' "$CFG" > "$CFG/autostart/conky-system.desktop"
# hide lxqt-powermanagement's tray icon — its built-in charge indicator is a
# code-drawn green ring (not themeable) and the theme/battery icon types render
# blank on this stack; battery status lives in Conky instead (BAT_LINE above).
# The daemon stays running (lid/idle/battery watching); only its icon is hidden.
PMC="$CFG/lxqt/lxqt-powermanagement.conf"
if [ -f "$PMC" ]; then
    bak "$PMC"
    if grep -q '^showIcon=' "$PMC"; then sed -i 's/^showIcon=.*/showIcon=false/' "$PMC"
    elif grep -q '^\[General\]' "$PMC"; then sed -i '/^\[General\]/a showIcon=false' "$PMC"
    else printf '[General]\nshowIcon=false\n' >> "$PMC"; fi
fi
ok "picom / rofi / conky configs (+ battery in conky, power tray icon hidden)"

# ============================================================ apply live
log "applying live"
# Super_L -> menu, via LXQt's own global-shortcut daemon (cleaner than xcape; this
# LXQt build binds a bare Super fine). The daemon OWNS globalkeyshortcuts.conf and
# rewrites it on exit, so we must stop it BEFORE editing or our entry is clobbered:
# stop -> edit (idempotent, skips if Super_L already bound) -> start to reload.
MENU=$(grep -E '^plugins=' "$PC" 2>/dev/null | tr ',' '\n' | grep -oE 'fancymenu|mainmenu' | head -1); : "${MENU:=mainmenu}"
pkill -x lxqt-globalkeysd 2>/dev/null; sleep 1
python3 - "$CFG/lxqt/globalkeyshortcuts.conf" "$MENU" <<'PY'
import sys,os,re
p,menu=sys.argv[1],sys.argv[2]
path='/panel/%s/show_hide'%menu
default="[General]\nAllowGrabBaseKeypad=true\nAllowGrabBaseSpecial=false\nAllowGrabLocks=false\nAllowGrabMiscKeypad=true\nAllowGrabMiscSpecial=true\nMultipleActionsBehaviour=first\n"
t=open(p).read() if os.path.exists(p) else default
if re.search(r'^\[Super_L\.', t, re.M):
    print('Super_L already bound — leaving user binding as-is'); open(p,'w').write(t); sys.exit(0)
ids=[int(m) for m in re.findall(r'^\[[^\]]*\.(\d+)\]', t, re.M)]
n=(max(ids)+1) if ids else 1
open(p,'w').write(t.rstrip('\n')+'\n\n[Super_L.%d]\nComment=Show/hide main menu\nEnabled=true\npath=%s\n'%(n,path))
print('bound Super_L ->',path)
PY
command -v lxqt-globalkeysd >/dev/null 2>&1 && setsid lxqt-globalkeysd >/dev/null 2>&1 &
pkill -9 -x lxqt-panel 2>/dev/null; sleep 2   # lxqt-session respawns exactly one (reads new config)
command -v openbox >/dev/null 2>&1 && openbox --reconfigure 2>/dev/null
# reload the desktop so it picks up the new icon theme + the cleared shortcuts.
# MUST be -9: a graceful pcmanfm-qt exit rewrites settings.conf, restoring
# DesktopShortcuts to defaults and clobbering our clean-desktop edit. SIGKILL
# skips that write, so the fresh instance reads our config. (A re-login is the
# definitive apply — the closing message says so.)
if pgrep -x pcmanfm-qt >/dev/null 2>&1; then
    pkill -9 -x pcmanfm-qt 2>/dev/null; sleep 2
    pgrep -x pcmanfm-qt >/dev/null 2>&1 || setsid pcmanfm-qt --desktop --profile=lxqt >/dev/null 2>&1 &
fi
for a in picom plank conky; do
    command -v "$a" >/dev/null 2>&1 || continue
    pkill -x "$a" 2>/dev/null; sleep 1
    case "$a" in
        picom) setsid picom --config "$CFG/picom/picom.conf" >/dev/null 2>&1 & ;;
        plank) setsid plank >/dev/null 2>&1 & ;;
        conky) setsid conky -c "$CFG/conky/conky.conf" >/dev/null 2>&1 &
               [ -f "$CFG/conky/conky-system.conf" ] && setsid env LC_CTYPE=C.UTF-8 conky -c "$CFG/conky/conky-system.conf" >/dev/null 2>&1 & ;;
    esac
done
# restart power management so showIcon=false takes effect (drops the tray icon)
if pgrep -f lxqt-powermanagement >/dev/null 2>&1; then
    pkill -f lxqt-powermanagement 2>/dev/null; sleep 1
    command -v lxqt-powermanagement >/dev/null 2>&1 && setsid lxqt-powermanagement >/dev/null 2>&1 &
fi

cat <<EOF

${K}Cachy-Void desktop applied.${Z}
  * Log out / back in once for every app to pick up the Kvantum style + env.
  * Menu:      tap Super (Windows key)      Launcher: Super+Space (Rofi)
  * Revert:    cachy-branding --remove      (then log out/in)
EOF
